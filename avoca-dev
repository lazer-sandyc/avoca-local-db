#!/usr/bin/env bash
# avoca-dev — a local development database for avoca-next, sourced from STAGING.
#
# Stands up a local Supabase stack and SNAPSHOTS staging into it — schema + data,
# since staging's app schemas are small and carry no PII. (SOURCE_DB=production instead
# does a schema-only prod mirror.) Points a worktree's env at it and gives you a
# one-command dev loop. Everything is reversible; the upstream is only ever read.
#
#   avoca-dev setup                 # one-time: snapshot staging into local (schema + data) + a login user
#   avoca-dev reference             # (re)load global lookup data from the source (voices, llm_models, transcribers, …)
#   avoca-dev seed                  # load synthetic test teams (English/Spanish agents for transfer tests)
#   avoca-dev duplicate-bp   <id>   # copy a modular blueprint (+versions/variables) from the source
#   avoca-dev duplicate-team <id>   # copy a team's CONFIG + its last week of real calls (calls need SOURCE_DB=production)
#   avoca-dev duplicate-team <id> --no-calls | --since <days> | --limit <n>   # config-only / widen / cap the call import
#   avoca-dev dup-calls      <id> [--since <days> | --limit <n>]  # import real calls into an already-cloned local team (default: last week)
#   avoca-dev delete-team    <id>   # inverse: release its local Twilio subaccount + purge the team from local
#   avoca-dev db up|down|cycle      # start / stop / restart the local Supabase stack (handles the -x excludes)
#   avoca-dev db setdev  [worktree] # point a worktree's env at the LOCAL db
#   avoca-dev db setprod [worktree] # revert it to the PROD db
#   avoca-dev db status  [worktree] # show which db each app is on
#   avoca-dev migrate [up|pending|executed] [wt]  # run unmerged migrations against LOCAL (the cheap loop)
#   avoca-dev types      [worktree] # regen Supabase types from the LOCAL schema (not prod)
#   avoca-dev up         [worktree] # bring the local DB up + point env local + drop stale bundle (you run pnpm dev)
#   avoca-dev oauth <client-id> <secret>   # wire Google sign-in locally (needs a stack restart)
#   avoca-dev trim                  # cut the Supabase stack to the ~7 containers we use
#   avoca-dev twilio provision   [team]   # subaccount for one team, or (no arg) every seeded team — idempotent (seed does this too)
#   avoca-dev twilio deprovision [team]   # reclaim one, or (no arg) ALL local subaccounts — run this on plan/worktree close
#   avoca-dev twilio status               # audit the subaccounts we provisioned
#   avoca-dev status                # show the stack + db + worktree pointers
#   avoca-dev clear [--keep-db]     # teardown: setprod every LOCAL worktree, then wipe + stop the stack
#
# Config: copy config.example.sh -> config.sh and edit, or override any var via env.

set -euo pipefail

SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ── Config (env overrides > config.sh > defaults) ─────────────────────────
[ -f "$SELF_DIR/config.sh" ] && . "$SELF_DIR/config.sh"
: "${AVOCA_NEXT_DIR:=$HOME/code/lazer/avoca/avoca-next}"                 # canonical clone
: "${WORKTREES_DIR:=$HOME/code/lazer/avoca/avoca-next.worktrees}"        # where worktrees live
: "${LOCAL_DB_DIR:=$SELF_DIR}"              # supabase-local home
: "${APP_SCHEMAS:=public,crm_service_titan,twilio}"                      # schemas to mirror
: "${REFERENCE_TABLES:=}"                                                # EXTRA global tables to sync beyond SYNC_CORE (per-machine additions)
: "${REFERENCE_SOURCE:=production}"                                      # global config is prod-accurate (staging is sparse) — always sync from prod
: "${PROD_PROJECT_REF:=wmizcewjcybhvkpwpmim}"                            # prod supabase ref
: "${PROD_ENV_FILE:=$AVOCA_NEXT_DIR/apps/web/.env.local}"               # legacy fallback source of the PROD db url
: "${AVOCA_CREDS_FILE:=$HOME/.avoca/postgres.env}"                       # Avoca's personal creds: STAGING_POSTGRES_URL + PROD_POSTGRES_URL
: "${SOURCE_DB:=staging}"                                                # upstream avoca-dev READS from: staging (default) | production
: "${SUPABASE_EXCLUDE:=logflare,vector}"                                 # containers to skip on 'supabase start' (analytics stack is flaky + unneeded for dev)
: "${LOGIN_EMAIL:=avoca-user@avoca.ai}"                                        # seeded password login (@avoca.ai => admin)
: "${LOGIN_PASSWORD:=avoca-pass}"
: "${LOGIN_NAME:=Local Dev}"
# Synthetic owner + enterprise a duplicated prod team is re-attached to, so we
# never copy real owner PII (auth.users/profiles). Must match seed/base.sql.
: "${SEED_OWNER_ID:=b0000000-0000-0000-0000-000000000001}"
: "${SEED_ENTERPRISE_ID:=990000}"

# Global config tables synced from prod so a local matches what people expect from
# production (staging is sparse on these). THE LIST GROWS — add a table here whenever a
# prod-only global setting bites you locally (feature flags were the first beyond lookups).
SYNC_CORE="voices,llm_models,transcribers,feature_flags"

die() { echo "avoca-dev: $*" >&2; exit 1; }
log() { echo "▸ $*"; }
need() {
  command -v "$1" >/dev/null 2>&1 && return
  case "$1" in
    supabase)     die "missing the 'supabase' CLI. Install it:  brew install supabase/tap/supabase   (docs: supabase.com/docs/guides/cli)";;
    psql|pg_dump) die "missing '$1' (Postgres client). Install it:  brew install libpq && brew link --force libpq";;
    docker)       die "missing 'docker'. Install a Docker engine: Docker Desktop, OrbStack, or colima.";;
    *)            die "missing '$1' on PATH";;
  esac
}

# Local Supabase status → env-style values (API_URL, ANON_KEY, SERVICE_ROLE_KEY, DB_URL)
sb_env() { ( cd "$LOCAL_DB_DIR" && supabase status -o env 2>/dev/null || true ); }
sbval()  { printf '%s\n' "$1" | sed -nE "s/^$2=\"?([^\"]+)\"?\$/\1/p" | head -1; }

# Local Postgres connection (super-user, for schema/seed/grants)
LP_HOST=127.0.0.1; LP_PORT=54322; LP_USER=postgres; LP_PASS=postgres; LP_DB=postgres
lsql() { PGPASSWORD="$LP_PASS" psql -h "$LP_HOST" -p "$LP_PORT" -U "$LP_USER" -d "$LP_DB" "$@"; }
LOCAL_PG_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# Resolve a worktree arg (path | slug | empty=canonical clone) to an absolute path
resolve_worktree() {
  local t="${1:-}"
  if   [ -z "$t" ];                       then echo "$AVOCA_NEXT_DIR"
  elif [ -d "$t/apps/web" ];              then ( cd "$t" && pwd )
  elif [ -d "$WORKTREES_DIR/$t/apps/web" ]; then echo "$WORKTREES_DIR/$t"
  else die "worktree not found: '$t' (looked in $WORKTREES_DIR/)"; fi
}

# LOCAL / prod / - for a given .env.local (by its effective NEXT_PUBLIC_SUPABASE_URL)
ptr_tag() {
  local f="$1"; [ -f "$f" ] || { echo "-"; return; }
  local u; u="$(grep -E '^NEXT_PUBLIC_SUPABASE_URL=' "$f" | tail -1 | cut -d= -f2- | tr -d '"')"
  case "$u" in *127.0.0.1*|*localhost*) echo LOCAL;; "" ) echo "-";; *) echo prod;; esac
}

# ── setup: stand up the local DB (staging snapshot by default) ────────────
# STAGING (default): full schema+data snapshot of the app schemas (small, no PII).
# PRODUCTION (SOURCE_DB=production): schema-only mirror + reference data (prod is huge/PII).
cmd_setup() {
  need supabase; need psql; need pg_dump
  IFS=',' read -ra SCHEMAS <<< "$APP_SCHEMAS"

  log "supabase stack in $LOCAL_DB_DIR"
  mkdir -p "$LOCAL_DB_DIR"
  [ -f "$LOCAL_DB_DIR/supabase/config.toml" ] || ( cd "$LOCAL_DB_DIR" && yes n | supabase init >/dev/null 2>&1 || true )
  ( cd "$LOCAL_DB_DIR" && supabase start ${SUPABASE_EXCLUDE:+-x "$SUPABASE_EXCLUDE"} ) || die "supabase start failed (try 'supabase start --debug' in $LOCAL_DB_DIR; or widen SUPABASE_EXCLUDE)"

  local existing; existing="$(lsql -tAc "SELECT count(*) FROM information_schema.tables WHERE table_schema='public';" 2>/dev/null || echo 0)"
  if [ "${existing:-0}" -gt 0 ]; then
    log "schema already loaded ($existing public tables); skipping load (use 'avoca-dev reset' to rebuild)"
  else
    local src_url; src_url="$(_source_url)"   # session endpoint + hardened via _src_pgdump
    lsql -q -c "DROP SCHEMA IF EXISTS public CASCADE; $(for s in "${SCHEMAS[@]}"; do [ "$s" = public ] || echo "DROP SCHEMA IF EXISTS $s CASCADE;"; done) CREATE SCHEMA public;"
    lsql -q -c "CREATE EXTENSION IF NOT EXISTS pg_trgm SCHEMA public; CREATE EXTENSION IF NOT EXISTS btree_gin SCHEMA public; CREATE EXTENSION IF NOT EXISTS btree_gist SCHEMA public; CREATE EXTENSION IF NOT EXISTS moddatetime SCHEMA public; CREATE EXTENSION IF NOT EXISTS \"uuid-ossp\" SCHEMA public; CREATE EXTENSION IF NOT EXISTS pgcrypto SCHEMA public; CREATE EXTENSION IF NOT EXISTS citext SCHEMA public; CREATE EXTENSION IF NOT EXISTS unaccent SCHEMA public;"
    local args=(); for s in "${SCHEMAS[@]}"; do args+=(--schema="$s"); done
    local tmp; tmp="$(mktemp -t avoca-snapshot.XXXX.sql)"
    case "$SOURCE_DB" in
      production|prod)
        # PROD: schema-only (prod data is huge + PII). Reference/config come via cmd_reference / duplicate-team.
        log "load prod SCHEMA only (READ-ONLY; prod data is huge + has PII)"
        _src_pgdump "$src_url" --schema-only --no-owner --no-privileges "${args[@]}" \
          | grep -viE '^SET transaction_timeout' | grep -viE '^CREATE SCHEMA public;' > "$tmp"
        lsql -v ON_ERROR_STOP=0 -q -f "$tmp" 2>&1 | grep -iE 'error' | grep -viE 'already exists' | head -20 || true
        ;;
      *)
        # STAGING (default): full snapshot — schema + DATA. Staging's app schemas are only
        # tens of MB and carry no real PII (calls/customers/bookings are empty), so we just
        # clone them. Load with FK triggers OFF (session_replication_role=replica) so insert
        # order and cross-schema FKs (e.g. public.profiles -> auth.users, which we don't copy)
        # never block the restore.
        log "snapshot $SOURCE_DB (schema + data, READ-ONLY) — app schemas only (~tens of MB, no PII)"
        _src_pgdump "$src_url" --no-owner --no-privileges "${args[@]}" \
          | grep -viE '^SET transaction_timeout' | grep -viE '^CREATE SCHEMA public;' > "$tmp"
        lsql -v ON_ERROR_STOP=0 -q >/dev/null 2>&1 <<SQL || true
SET session_replication_role = replica;
\i $tmp
SQL
        ;;
    esac
    rm -f "$tmp"
    local loaded; loaded="$(lsql -tAc "SELECT count(*) FROM information_schema.tables WHERE table_schema='public';")"
    [ "${loaded:-0}" -gt 50 ] || die "schema load looks incomplete ($loaded public tables)"
    log "loaded $loaded public tables"
  fi

  cmd_grants
  cmd_ledger
  cmd_reference             # sync global prod config (lookups + feature flags) so local matches production
  _ensure_synthetic_owner   # synthetic owner/enterprise so duplicate-team works out of the box (NOT the Test Auto teams)
  _seed_login               # local login user
  log "setup done. Log in as $LOGIN_EMAIL, and clone a real team: SOURCE_DB=production avoca-dev duplicate-team <id>"
  log "  run your app: avoca-dev db setdev <worktree> then your normal pnpm dev.  (synthetic transfer test teams: avoca-dev seed)"
}

# Reference / lookup data the app genuinely needs to function (voice list, LLM
# models, transcribers, …) — global tables, no team scope, no PII. Copied
# data-only from  (READ-ONLY) and idempotent: --inserts --on-conflict-do-nothing
# so re-running never duplicates. Edit REFERENCE_TABLES (config.sh) to add more.
# ── source reads: hardened + attributable ────────────────────────────────
# The transaction pooler (Supavisor) STRIPS libpq startup options — PGOPTIONS and a
# startup application_name don't survive it (verified: read_only stayed off, app came
# back 'Supavisor'). But it DOES honor `SET` sent as SQL on a session-mode (:5432)
# connection. So we harden psql by injecting SETs, which the server then enforces:
#   default_transaction_read_only=on — writes are IMPOSSIBLE (any write errors out)
#   statement_timeout=60s            — no single query can run long
#   lock_timeout=3s                  — never WAIT on a lock (can't block / be blocked)
#   idle_in_transaction=120s         — a stalled session can't sit on its locks
#   application_name=avoca-dev-local — every connection is name-tagged in pg_stat_activity
# (All verified live: ro_txn=on, a write rejected, app=avoca-dev-local.)
SRC_APPNAME="avoca-dev-local"
# Client-side hard kill for a hung read (coreutils timeout/gtimeout if present; else skip).
_TIMEOUT_BIN="$(command -v timeout 2>/dev/null || command -v gtimeout 2>/dev/null || true)"
# Our own independent record of every source read (url redacted — no secrets on disk).
SRC_AUDIT_LOG="${SRC_AUDIT_LOG:-$HOME/.avoca-dev/source-reads.log}"
_src_audit() {
  mkdir -p "$(dirname "$SRC_AUDIT_LOG")" 2>/dev/null || true
  printf '%s\t%s\n' "$(date '+%Y-%m-%dT%H:%M:%S%z')" "$1" >> "$SRC_AUDIT_LOG" 2>/dev/null || true
}
_redact() { printf '%s' "$*" | sed -E 's#postgres(ql)?://[^[:space:]]*#<source-url>#g'; }

# The upstream Postgres url we READ to mirror schema / reference data / configs.
# Defaults to STAGING (SOURCE_DB) from Avoca's ~/.avoca/postgres.env — so everyday
# setup/reference never touches prod. Falls back to the app's Vercel-pulled POSTGRES_URL
# only for SOURCE_DB=production on a machine not yet on ~/.avoca/postgres.env.
# Rewritten to the SESSION pooler endpoint (:5432): pg_dump needs session semantics,
# and the SET-based hardening only persists on a session-mode connection (not :6543).
_source_url() {
  local key u
  case "$SOURCE_DB" in
    staging|stage)   key=STAGING_POSTGRES_URL ;;
    production|prod) key=PROD_POSTGRES_URL ;;
    *) die "SOURCE_DB must be 'staging' or 'production' (got '$SOURCE_DB')" ;;
  esac
  if [ -f "$AVOCA_CREDS_FILE" ] && grep -qE "^$key=" "$AVOCA_CREDS_FILE"; then
    u="$(grep -E "^$key=" "$AVOCA_CREDS_FILE" | tail -1 | cut -d= -f2- | tr -d '"')"
  elif [ "$SOURCE_DB" = production ] || [ "$SOURCE_DB" = prod ]; then
    u="$(grep -E '^(POSTGRES_URL|PROD_URL)=' "$PROD_ENV_FILE" 2>/dev/null | tail -1 | cut -d= -f2- | tr -d '"')"  # legacy fallback
  fi
  [ -n "${u:-}" ] || die "no $key in $AVOCA_CREDS_FILE — paste your creds there (1Password), or run with SOURCE_DB=production"
  printf '%s\n' "$(printf '%s' "$u" | sed -E 's#:6543/#:5432/#')"
}

# Hardened, audited prod psql. Call as: _src_psql <url> [psql args…]. Injects the SETs
# before the caller's query; under -q the SET tags don't leak into captured output (verified).
# READ-ONLY (server-enforced), time-bounded, lock-yielding, name-tagged.
_src_psql() {
  local url="$1"; shift
  _src_audit "psql $(_redact "$url $*")"
  ${_TIMEOUT_BIN:+$_TIMEOUT_BIN 90} psql "$url" \
    -c "SET default_transaction_read_only=on" \
    -c "SET application_name='$SRC_APPNAME'" \
    -c "SET statement_timeout=60000" \
    -c "SET lock_timeout=3000" \
    -c "SET idle_in_transaction_session_timeout=120000" \
    "$@"
}
# Hardened, audited prod pg_dump. pg_dump is read-only by nature (SELECT + ACCESS SHARE
# only) and takes no SET, and the pooler strips startup options — so it can't be
# server-tagged (shows 'Supavisor'). It's bounded instead by --lock-wait-timeout + the
# client-side timeout, is read-only by construction, and is captured in the audit log.
_src_pgdump() {
  _src_audit "pg_dump $(_redact "$*")"
  ${_TIMEOUT_BIN:+$_TIMEOUT_BIN 180} pg_dump --lock-wait-timeout=3000 "$@"
}

cmd_reference() {
  need psql; need pg_dump
  local src_url; src_url="$(SOURCE_DB="$REFERENCE_SOURCE" _source_url)"   # always prod: staging is sparse on global config
  # tool-owned SYNC_CORE (grows over time) + optional per-machine REFERENCE_TABLES extras, deduped
  local tables; tables="$(echo "$SYNC_CORE,${REFERENCE_TABLES:-}" | tr ',' '\n' | awk 'NF && !seen[$0]++' | paste -sd, -)"
  IFS=',' read -ra RTABLES <<< "$tables"
  log "sync global config from $REFERENCE_SOURCE (READ-ONLY, prod-parity): $tables"
  for t in "${RTABLES[@]}"; do
    [ -n "$t" ] || continue
    # REPLACE local rows with prod's (a clean mirror — matters for tables like feature_flags
    # whose serial-id PK would make an additive copy silently skip rows). Under replica role
    # (FK triggers off) so delete + reload never blocks on order or cross-references.
    printf 'SET session_replication_role=replica;\nDELETE FROM public.%s;\n' "$t" | lsql -q >/dev/null 2>&1 || true
    { printf 'SET session_replication_role=replica;\n'; _src_pgdump "$src_url" --data-only --no-owner --no-privileges --table="public.$t" 2>/dev/null; } \
      | lsql -q -v ON_ERROR_STOP=0 2>&1 | grep -iE 'error' | grep -viE 'already exists' | head -5 || true
    local n; n="$(lsql -tAc "select count(*) from public.$t" 2>/dev/null || echo '?')"
    log "  $t: $n rows"
  done
}

# ── duplicate: copy a real prod record graph (config only) into local ─────
# Prod is READ-ONLY. Loads run on the LOCAL side with FK triggers disabled
# (session_replication_role=replica) so insert order never matters and circular
# refs are fine; and via COPY so identity/serial ids are preserved EXACTLY —
# that's what keeps foreign keys valid across the copy.

# Non-generated column list for a table (keeps identity/serial, drops STORED
# generated columns which COPY cannot accept).
_cols() {
  lsql -tAc "select string_agg(quote_ident(column_name), ', ' order by ordinal_position)
             from information_schema.columns
             where table_schema='public' and table_name='$1' and is_generated='NEVER'"
}

# Copy rows prod -> local for one table.  _pull <src_url> <table> <where-sql>
# Runs under replica role; caller is responsible for clearing stale rows first.
_pull() {
  local url="$1" tbl="$2" where="$3"
  # Copy only columns present in BOTH source and local. Local can carry un-merged
  # migration columns the source lacks (e.g. a not-yet-deployed feature column) — and
  # selecting those from the source errors. The intersection avoids that; COPY column
  # order is irrelevant as long as SELECT and COPY use the same list (they do).
  local srccols localcols cols
  srccols="$(_src_psql "$url" -tAqc "select column_name from information_schema.columns where table_schema='public' and table_name='$tbl' and is_generated='NEVER'" 2>/dev/null)"
  [ -n "$srccols" ] || die "unknown/empty table in $SOURCE_DB: $tbl"
  localcols="$(lsql -tAqc "select column_name from information_schema.columns where table_schema='public' and table_name='$tbl' and is_generated='NEVER'" 2>/dev/null)"
  cols="$(comm -12 <(printf '%s\n' "$srccols" | sort -u) <(printf '%s\n' "$localcols" | sort -u) | grep . | sed 's/.*/"&"/' | paste -sd, - 2>/dev/null || true)"
  [ -n "$cols" ] || die "no shared columns for $tbl between $SOURCE_DB and local"
  local tmp; tmp="$(mktemp -t avoca-pull.XXXX)"
  _src_psql "$url" -qX -c "\copy (select $cols from public.$tbl where $where) to '$tmp'" >/dev/null 2>"$tmp.err" \
    || { cat "$tmp.err" >&2; rm -f "$tmp" "$tmp.err"; die "prod read failed for $tbl"; }
  local n; n="$(wc -l < "$tmp" | tr -d ' ')"
  lsql -q >/dev/null 2>&1 <<SQL
set session_replication_role = replica;
\copy public.$tbl ($cols) from '$tmp'
SQL
  rm -f "$tmp" "$tmp.err"
  log "  $tbl: +$n rows"
}

# duplicate-bp <blueprint_id>: copy a modular blueprint (+ its versions and
# assistant variables) from prod so the builder / clone-from-template works.
cmd_duplicate_bp() {
  local id="${1:?usage: avoca-dev duplicate-bp <blueprint_id>}"
  need psql
  local url; url="$(_source_url)"
  local name; name="$(_src_psql "$url" -tAqc "select name from public.multi_agent_blueprints where id='$id'" 2>/dev/null | tr -d ' ')"
  [ -n "$name" ] || die "no blueprint '$id' in prod"
  log "duplicate blueprint '$id' from $SOURCE_DB (READ-ONLY)"
  # idempotent: drop any prior copy first (FK triggers off, so order is free)
  lsql -q >/dev/null 2>&1 <<SQL
set session_replication_role = replica;
delete from public.assistant_variables_versions   where blueprint_id='$id';
delete from public.assistant_variables            where blueprint_id='$id';
delete from public.multi_agent_blueprint_versions where blueprint_id='$id';
delete from public.multi_agent_blueprints          where id='$id';
SQL
  _pull "$url" multi_agent_blueprints         "id='$id'"
  _pull "$url" multi_agent_blueprint_versions "blueprint_id='$id'"
  _pull "$url" assistant_variables            "blueprint_id='$id'"
  _pull "$url" assistant_variables_versions   "blueprint_id='$id'"
  log "done — blueprint is now in local."
}

# Remove every locally-copied row for a team (the config allowlist). FK triggers
# off => order-free. Does NOT touch Twilio or team_twilio_configs.
_purge_team_local() {
  local team="$1"
  lsql -q >/dev/null 2>&1 <<SQL
set session_replication_role = replica;
delete from public.knowledge_bases                 where team_id=$team;
delete from public.team_call_reasons               where team_id=$team;
delete from public.team_transfer_reasons           where team_id=$team;
delete from public.assistant_variables_versions   where team_id=$team;
delete from public.assistant_variables             where team_id=$team;
delete from public.transfer_destination_assistants where team_id=$team;
delete from public.transfer_destinations           where team_id=$team;
delete from public.assistant_config_versions       where config_id in (select id from public.assistant_configs where team_id=$team);
delete from public.assistant_configs               where team_id=$team;
delete from public.voice_assistants                where team_id=$team;
delete from public.responder_webhook_configs       where team_id=$team;
delete from public.phone_numbers                   where team_id=$team;
delete from public.teams                           where id=$team;
SQL
}

# delete-team <team_id>: the inverse of duplicate-team — get rid of a test team
# you're done with. The local DB is shared across ALL worktrees, so teardown is
# per-team, not per-worktree. Releases the team's local Twilio subaccount first
# (tag-gated — only ever closes an 'avoca-dev-local' subaccount), then purges its
# config rows. Referenced blueprints are left (they're global / may be shared).
cmd_delete_team() {
  local team="${1:?usage: avoca-dev delete-team <team_id>}"
  need psql
  local name; name="$(lsql -tAc "select name from teams where id=$team" 2>/dev/null)"
  [ -n "$name" ] || die "no team $team in local db"
  local sub; sub="$(lsql -tAc "select subaccount_sid from team_twilio_configs where team_id=$team limit 1" 2>/dev/null)"
  if [ -n "$sub" ]; then
    if command -v python3 >/dev/null 2>&1 && _twilio_creds_soft; then
      log "release local Twilio subaccount for team $team ($sub)"
      ( _tw_deprovision_one "$team" ) || log "  twilio deprovision incomplete — run 'avoca-dev twilio deprovision $team'"
    else
      die "team $team has a live Twilio subaccount ($sub) but no ISV creds here to close it. Run 'avoca-dev twilio deprovision $team' with creds first, or you'll orphan it on Avoca's account."
    fi
  fi
  log "delete team $team ('$name') + its config from local"
  _purge_team_local "$team"
  log "done — team $team removed."
}

# duplicate-team <team_id>: copy a real prod team's CONFIG (agents, voice
# assistants, phone routing, transfer destinations, variables) into local —
# NOT its runtime data (calls/CRM/analytics/logs). Every external-provider
# handle is scrubbed on the way in (see below) so no local action can ever
# mutate the real Twilio/Vapi/ElevenLabs asset, and the team is re-attached to
# the synthetic seed owner/enterprise so no owner PII is copied. Referenced
# modular blueprints are auto-pulled. Idempotent (drops any prior copy first).
cmd_duplicate_team() {
  local team="${1:?usage: avoca-dev duplicate-team <team_id> [--since <days> | --limit <n> | --no-calls]}"; shift || true
  # By DEFAULT we also import the team's last week of real calls. This only yields data
  # when SOURCE_DB=production (calls live in prod; staging is call-empty), so it's a
  # harmless no-op on the default staging source. --no-calls = config only (no call PII).
  local calls_since=7 calls_limit="" calls_off=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --no-calls)     calls_off=1; shift;;
      --with-calls)   shift;;                       # accepted alias — default is already on
      --with-calls=*) calls_limit="${1#*=}"; shift;;
      --since)        calls_since="${2:?--since needs a number of days}"; shift 2;;
      --since=*)      calls_since="${1#*=}"; shift;;
      --limit)        calls_limit="${2:?--limit needs a number}"; shift 2;;
      --limit=*)      calls_limit="${1#*=}"; shift;;
      *) die "unknown arg: $1 (usage: duplicate-team <team_id> [--since <days> | --limit <n> | --no-calls])";;
    esac
  done
  need psql
  local url; url="$(_source_url)"
  local name; name="$(_src_psql "$url" -tAqc "select name from public.teams where id=$team" 2>/dev/null | sed 's/^ *//;s/ *$//')"
  [ -n "$name" ] || die "no team $team in prod"
  local src_ent; src_ent="$(_src_psql "$url" -tAqc "select enterprise_id from public.teams where id=$team" 2>/dev/null | tr -d '[:space:]')"
  _ensure_synthetic_owner   # create the synthetic owner/enterprise if missing (no 'seed' prereq)
  log "duplicate team $team ('$name') from $SOURCE_DB (READ-ONLY; config only; provider handles scrubbed)"

  _purge_team_local "$team"   # drop any prior copy so re-runs are idempotent

  _pull "$url" teams                           "id=$team"
  _pull "$url" phone_numbers                   "team_id=$team"
  _pull "$url" voice_assistants                "team_id=$team"
  _pull "$url" assistant_configs               "team_id=$team"
  _pull "$url" assistant_config_versions       "config_id in (select id from public.assistant_configs where team_id=$team)"
  _pull "$url" transfer_destinations           "team_id=$team"
  _pull "$url" transfer_destination_assistants "team_id=$team"
  # Prompt inputs + reasons: the KB feeds the compiled agent prompt (service info,
  # hours, FAQs) — without it a cloned team's calls fail. team_transfer_reasons
  # backs transfer_destinations.transfer_reason_ids; team_call_reasons backs
  # bookability/call-reason tagging. All per-team rows keyed by team_id.
  _pull "$url" knowledge_bases                 "team_id=$team"
  _pull "$url" team_call_reasons               "team_id=$team"
  _pull "$url" team_transfer_reasons           "team_id=$team"
  _pull "$url" responder_webhook_configs       "team_id=$team"
  _pull "$url" assistant_variables             "team_id=$team"
  _pull "$url" assistant_variables_versions    "team_id=$team"

  # Make sure THIS team's own enterprise exists locally (just the enterprise row,
  # not its sibling teams), so the copy keeps its real enterprise instead of the
  # synthetic one. Skip if already local (another duplicated team shares it), and
  # fall back to the synthetic enterprise when the source team has none.
  local attach_ent="$SEED_ENTERPRISE_ID"
  if [ -n "$src_ent" ] && [ "$src_ent" != "$SEED_ENTERPRISE_ID" ]; then
    if [ -n "$(lsql -tAc "select 1 from enterprises where id=$src_ent" 2>/dev/null)" ]; then
      log "  enterprise $src_ent already local — reuse"
    else
      log "  ↳ duplicating the team's enterprise $src_ent"
      _pull "$url" enterprises "id=$src_ent"
      # billing handle + default template are prod-scoped: null them so nothing
      # local chases a dangling template FK or a real Orb customer.
      lsql -q >/dev/null 2>&1 <<SQL
set session_replication_role = replica;
update public.enterprises set orb_customer_id=null, default_template_id=null where id=$src_ent;
SQL
    fi
    attach_ent="$src_ent"
  fi

  # Re-attach to the synthetic owner + the team's own enterprise (no PII), scrub the agent-level
  # provider handle, and DELETE the copied phone numbers outright. We keep none
  # of prod's numbers: they'd be inert config at best, and a rediscovery risk at
  # worst — once ISV creds are present locally (required to test telephony), the
  # app can identify a number in Twilio by its E.164 and repoint the REAL one.
  # Dropping them forces you to provision a fresh LOCAL number (which you must do
  # to test anyway) and leaves zero real digits in any table. FK triggers are off
  # (replica role), so we clear the referencing columns by hand — locally the
  # blocking children (calls, team_test_plans, workflow_campaigns, …) are never
  # copied, so only voice_assistants / transfer_destinations point at a number.
  lsql -q >/dev/null 2>&1 <<SQL
set session_replication_role = replica;
update public.teams set owner_id='$SEED_OWNER_ID', enterprise_id=$attach_ent where id=$team;
update public.voice_assistants
   set main_inbound_call_phone_id=null, backup_inbound_call_phone_id=null, test_inbound_call_phone_id=null
 where team_id=$team;
update public.transfer_destinations td set number=null
  from public.phone_numbers p
 where p.team_id=$team and td.team_id=$team and td.number = p.phone_number;
delete from public.phone_numbers where team_id=$team;
update public.assistant_configs set vapi_assistant_id=null where team_id=$team;
SQL

  # auto-pull any modular blueprints this team's agents reference
  local bps; bps="$(_src_psql "$url" -tAqc "
    select distinct v.blueprint_id from public.multi_agent_blueprint_versions v
    where v.id in (
      select blueprint_version_id from public.assistant_configs
        where team_id=$team and blueprint_version_id is not null
      union
      select blueprint_version_id from public.assistant_config_versions
        where config_id in (select id from public.assistant_configs where team_id=$team)
          and blueprint_version_id is not null
    )" 2>/dev/null)"
  for bp in $bps; do
    [ -n "$bp" ] || continue
    if [ -n "$(lsql -tAc "select 1 from multi_agent_blueprints where id='$bp'" 2>/dev/null)" ]; then
      log "  blueprint $bp already local — skip"
    else
      log "  ↳ auto-pulling referenced blueprint $bp"
      cmd_duplicate_bp "$bp"
    fi
  done

  # Auto-provision the team's Twilio ISV subaccount so the copy is call-ready.
  # Best-effort in a subshell: missing ISV creds or an API error warns but never
  # aborts the (already-complete) config clone. Idempotent — _tw_provision_one
  # skips a team that already has a subaccount. This provisions the subaccount
  # only; buy a test number in the UI to actually place a call.
  ( _twilio_creds && _tw_provision_one "$team" ) \
    || log "  twilio ISV not provisioned (no ISV creds, or API error) — run 'avoca-dev twilio provision $team' when ready"

  log "done — team $team ('$name') config + own enterprise in local (numbers dropped; provider handles scrubbed; owner→synthetic; twilio ISV provisioned — buy a number to place calls)."
  if [ -z "$calls_off" ]; then
    if [ -n "$calls_limit" ]; then cmd_dup_calls "$team" --limit "$calls_limit"
    else cmd_dup_calls "$team" --since "$calls_since"; fi
  fi
}

# dup-calls <team_id> [--since <days> | --limit <n>]: copy a BOUNDED slice of a team's
# real call history (calls + call_flows + transcripts/analysis + transfer notes) from the
# source into local, so the calls page has data and the reconciliation/linking path has
# rows to inspect. duplicate-team stays PII-free; THIS is the opt-in that knowingly brings
# real call content (transcripts, phone numbers) onto your LOCAL machine only. Recording
# AUDIO is NOT copied (Storage isn't mirrored), so stitch has no media to assemble.
# Idempotent: replaces this team's imported call rows each run. Default: newest 50 calls.
# Calls live in prod, so run: SOURCE_DB=production avoca-dev dup-calls <id>
cmd_dup_calls() {
  local team="${1:?usage: avoca-dev dup-calls <team_id> [--since <days> | --limit <n>]}"; shift || true
  need psql
  local since_days="" limit_n=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --since)   since_days="${2:?--since needs a number of days}"; shift 2;;
      --since=*) since_days="${1#*=}"; shift;;
      --limit)   limit_n="${2:?--limit needs a number}"; shift 2;;
      --limit=*) limit_n="${1#*=}"; shift;;
      *) die "unknown arg: $1 (usage: dup-calls <team_id> [--since <days> | --limit <n>])";;
    esac
  done
  [ -n "$since_days" ] && [ -n "$limit_n" ] && die "use --since OR --limit, not both"
  [ -n "$since_days$limit_n" ] || since_days=7   # default: last week of calls
  case "$since_days$limit_n" in *[!0-9]*) die "--since/--limit take a plain number";; esac

  local url; url="$(_source_url)"
  local name; name="$(_src_psql "$url" -tAqc "select name from public.teams where id=$team" 2>/dev/null | sed 's/^ *//;s/ *$//')"
  [ -n "$name" ] || die "no team $team in $SOURCE_DB (calls live in prod — try SOURCE_DB=production)"
  [ -n "$(lsql -tAc "select 1 from teams where id=$team" 2>/dev/null)" ] \
    || die "team $team isn't in local yet — run 'SOURCE_DB=$SOURCE_DB avoca-dev duplicate-team $team' first (calls FK to teams)"

  # source-side selector for THIS team's calls, bounded by window or count
  local sel
  if [ -n "$limit_n" ]; then
    sel="team_id=$team and id in (select id from public.calls where team_id=$team order by created_at desc nulls last limit $limit_n)"
    log "dup-calls team $team ('$name') from $SOURCE_DB — newest $limit_n calls (READ-ONLY)"
  else
    sel="team_id=$team and created_at >= now() - interval '$since_days days'"
    log "dup-calls team $team ('$name') from $SOURCE_DB — last $since_days days (READ-ONLY)"
  fi
  local callsub="select id from public.calls where $sel"

  # idempotent: clear this team's previously-imported call rows (children first; replica => order-free)
  lsql -q >/dev/null 2>&1 <<SQL
set session_replication_role = replica;
delete from public.transfer_destination_logs where source_call_id in (select id from public.calls where team_id=$team) or received_call_id in (select id from public.calls where team_id=$team);
delete from public.call_conversations where call_id in (select id from public.calls where team_id=$team);
delete from public.call_analysis      where call_id in (select id from public.calls where team_id=$team);
delete from public.calls              where team_id=$team;
delete from public.call_flows         where team_id=$team;
SQL

  # parents first (logging only; replica role makes FK order irrelevant)
  _pull "$url" call_flows "team_id=$team and id in (select call_flow_id from public.calls where $sel and call_flow_id is not null)"
  _pull "$url" calls                     "$sel"
  _pull "$url" call_conversations        "call_id in ($callsub)"
  _pull "$url" call_analysis             "call_id in ($callsub)"
  _pull "$url" transfer_destination_logs "source_call_id in ($callsub) or received_call_id in ($callsub)"

  local n; n="$(lsql -tAc "select count(*) from calls where team_id=$team" | tr -d ' ')"
  log "done — $n calls in local for team $team."
  echo "  PII: transcripts/analysis are REAL call content (LOCAL only, never shared). Recording audio is NOT mirrored, so stitch has no media."
}

# Supabase role grants (pg_dump --no-privileges strips these; without them the
# app gets 'permission denied for schema public' via PostgREST).
cmd_grants() {
  log "grant anon/authenticated/service_role on the app schemas"
  local schemas_sql="ARRAY['${APP_SCHEMAS//,/\',\'}']"
  lsql -q <<SQL 2>/dev/null
DO \$\$
DECLARE s text;
BEGIN
  FOREACH s IN ARRAY $schemas_sql LOOP
    EXECUTE format('GRANT USAGE ON SCHEMA %I TO anon, authenticated, service_role', s);
    EXECUTE format('GRANT ALL ON ALL TABLES IN SCHEMA %I TO anon, authenticated, service_role', s);
    EXECUTE format('GRANT ALL ON ALL SEQUENCES IN SCHEMA %I TO anon, authenticated, service_role', s);
    EXECUTE format('GRANT ALL ON ALL ROUTINES IN SCHEMA %I TO anon, authenticated, service_role', s);
    EXECUTE format('ALTER DEFAULT PRIVILEGES IN SCHEMA %I GRANT ALL ON TABLES TO anon, authenticated, service_role', s);
    EXECUTE format('ALTER DEFAULT PRIVILEGES IN SCHEMA %I GRANT ALL ON SEQUENCES TO anon, authenticated, service_role', s);
    EXECUTE format('ALTER DEFAULT PRIVILEGES IN SCHEMA %I GRANT ALL ON ROUTINES TO anon, authenticated, service_role', s);
  END LOOP;
END \$\$;
SQL
}

# Seed the umzug ledger from origin/main so 'db:up' only runs unmerged migrations.
cmd_ledger() {
  log "seed umzug ledger from origin/main"
  lsql -q -c "CREATE SCHEMA IF NOT EXISTS migrations; CREATE TABLE IF NOT EXISTS migrations.umzug_migrations (name text PRIMARY KEY);"
  ( cd "$AVOCA_NEXT_DIR" && git ls-tree -r --name-only origin/main -- packages/db/migrations/ 2>/dev/null ) \
    | sed -nE 's#packages/db/migrations/([0-9]+_[^/]+\.sql)$#\1#p' \
    | while IFS= read -r m; do [ -n "$m" ] && lsql -q -c "INSERT INTO migrations.umzug_migrations(name) VALUES ('$m') ON CONFLICT DO NOTHING;"; done || true
}

# ── reset: wipe the local DB back to empty, then re-run setup ─────────────
cmd_reset() {
  need supabase
  log "reset: supabase db reset (empties the DB; keeps the stack, auth, extensions)"
  ( cd "$LOCAL_DB_DIR" && supabase db reset ) || die "supabase db reset failed"
  cmd_setup
}

# Create the synthetic owner + enterprise if missing. duplicate-team re-attaches copied
# teams to these so no real owner PII lands locally. Created on demand by `setup` (so
# duplicate-team works out of the box) — you do NOT need the full `seed` (Test Auto teams)
# just to clone a real team. Idempotent.
_ensure_synthetic_owner() {
  need psql
  lsql -q >/dev/null 2>&1 <<SQL || true
INSERT INTO enterprises (id, name) VALUES ($SEED_ENTERPRISE_ID, 'Lazer Test Enterprise') ON CONFLICT (id) DO NOTHING;
INSERT INTO auth.users (id) VALUES ('$SEED_OWNER_ID') ON CONFLICT (id) DO NOTHING;
INSERT INTO profiles (id, email) VALUES ('$SEED_OWNER_ID', 'test-owner@lazer.local') ON CONFLICT (id) DO NOTHING;
SQL
}

# Create a LOCAL login user (auth.users + identity + profile) so you can sign in.
# Independent of staging/prod auth — we never copy those. Idempotent. Run by both
# `setup` (so login works out of the box) and `seed`.
_seed_login() {
  need psql
  log "seed login user $LOGIN_EMAIL / $LOGIN_PASSWORD (@avoca.ai => system admin)"
  lsql -q -v email="$LOGIN_EMAIL" -v pass="$LOGIN_PASSWORD" -v fullname="$LOGIN_NAME" -f "$SELF_DIR/seed/login-user.sql" 2>&1 | grep -iE 'error|confirmed|bcrypt|identity|profile' | head -10 || true
}

# ── seed: OPTIONAL synthetic Test Auto teams (owner + login come from setup) ─
cmd_seed() {
  need psql
  _ensure_synthetic_owner   # base.sql attaches the Test Auto teams to this
  log "load synthetic Test Team (English/Spanish agents + transfer destinations)"
  lsql -q -f "$SELF_DIR/seed/base.sql" 2>&1 | grep -iE 'error|^ *[a-z].*\| *[0-9]' | head -20 || true
  _seed_login
  # Twilio subaccounts are NOT provisioned here — do it on demand from the app UI,
  # or with 'avoca-dev twilio provision' when you actually need to buy numbers.
  log "seed done. (Twilio: provision on demand from the UI or 'avoca-dev twilio provision'.)"
}

# ── migrate: run unmerged migrations against LOCAL (the cheap dev loop) ───
# umzug reads the DISCRETE POSTGRES_* from process.env directly (no dotenv), and
# builds its connection from them — NOT from POSTGRES_URL. `db setdev` writes those
# into the worktree's apps/web/.env.local, but a bare `pnpm db:up` from packages/db
# never loads that file, so it dies on "Missing POSTGRES_DB". We export the LOCAL
# values inline here, which both closes that gap AND hard-pins the target to local
# (127.0.0.1:54322) — this command can never touch prod, whatever the worktree env says.
cmd_migrate() {
  local action="${1:-up}"; shift || true
  case "$action" in up|pending|executed|down) : ;; *) die "migrate action must be up|pending|executed|down (got '$action')";; esac
  local wt; wt="$(resolve_worktree "${1:-}")"
  lsql -tAc "select 1" >/dev/null 2>&1 || die "local DB unreachable at $LP_HOST:$LP_PORT — is the stack up? (avoca-dev setup)"
  log "migrate $action → LOCAL $LP_HOST:$LP_PORT/$LP_DB  (worktree $(basename "$wt"))"
  ( cd "$wt" \
    && POSTGRES_HOST="$LP_HOST" POSTGRES_PORT="$LP_PORT" POSTGRES_DB="$LP_DB" \
       POSTGRES_USER="$LP_USER" POSTGRES_PASSWORD="$LP_PASS" \
       pnpm --filter @avoca/db "db:$action" )
}

# ── types: regenerate Supabase types from the LOCAL schema ────────────────
# The repo's `gen-supabase-types` script hardcodes `--project-id <prod>`, so it
# types against prod — wrong for the local-first loop, where you want types that
# reflect the migration you just applied locally, BEFORE it's merged/deployed.
# This generates from the local DB directly and writes the same generated file.
cmd_types() {
  need supabase
  local wt; wt="$(resolve_worktree "${1:-}")"
  local out="$wt/packages/db/src/generated/supabase.generated.ts"
  [ -f "$out" ] || die "no generated types file at $out"
  lsql -tAc "select 1" >/dev/null 2>&1 || die "local DB unreachable at $LP_HOST:$LP_PORT — is the stack up? (avoca-dev setup)"
  log "regen Supabase types from LOCAL ($APP_SCHEMAS) → ${out#"$wt/"}"
  local tmp; tmp="$(mktemp -t avoca-types.XXXX.ts)"
  supabase gen types typescript --db-url "$LOCAL_PG_URL" --schema "$APP_SCHEMAS" > "$tmp" \
    || { rm -f "$tmp"; die "type gen failed (is the supabase CLI current? is the stack up?)"; }
  [ -s "$tmp" ] || { rm -f "$tmp"; die "type gen produced an empty file — aborting (kept the existing types)"; }
  mv "$tmp" "$out"
  log "done. build the package to pick them up:  pnpm --filter @avoca/db build"
}

# ── db: point a worktree's env local <-> prod ─────────────────────────────
BEGIN_MARK="# >>> avoca-dev managed: LOCAL db overrides (do not edit) >>>"
END_MARK="# <<< avoca-dev managed <<<"
strip_block() {
  local f="$1"; [ -f "$f" ] || return 0
  # Current format is a bounded block (BEGIN..END inclusive) — drop it but KEEP
  # anything after it (hand-added env the developer put below the managed block).
  # Legacy formats had no END marker, so those are still stripped to EOF.
  awk -v b="$BEGIN_MARK" -v e="$END_MARK" '
    index($0,b)==1 { inblk=1; next }
    inblk && index($0,e)==1 { inblk=0; next }
    inblk { next }
    index($0,"# --- shared local DB")==1 || index($0,"# >>> point-db managed")==1 { legacy=1 }
    legacy { next }
    { print }
  ' "$f" > "$f.adv1"
  # DB-only: strip the managed DB overrides. App-URL vars (WEB_APP_URL,
  # NEXT_PUBLIC_WEB_APP_URL, NEXT_PUBLIC_DASHBOARD_URL) are NOT touched here —
  # they belong to the worktree's env (FDE overrides / tunnel), not the DB switch.
  # The localhost app-URL lines are still stripped once, to clean up any env a
  # prior (coupled) version of this command wrote.
  grep -vxF -e "POSTGRES_HOST=127.0.0.1" -e "POSTGRES_PORT=54322" -e "POSTGRES_DB=postgres" \
    -e "POSTGRES_USER=postgres" -e "POSTGRES_PASSWORD=postgres" \
    -e "NEXT_PUBLIC_SUPABASE_URL=$LOCAL_API" \
    -e "POSTGRES_URL=$LOCAL_PG_URL" \
    -e "WEB_APP_URL=http://localhost:3000" -e "NEXT_PUBLIC_WEB_APP_URL=http://localhost:3000" \
    -e "NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3002" \
    "$f.adv1" > "$f.adv2" || true
  awk '{a[NR]=$0} END{last=NR; while(last>0 && a[last]==""){last--}; for(i=1;i<=last;i++) print a[i]}' "$f.adv2" > "$f"
  rm -f "$f.adv1" "$f.adv2"
}
# In DEV mode the managed block re-defines keys that ALSO have live originals in the
# Vercel-pulled env (NEXT_PUBLIC_SUPABASE_URL/ANON_KEY, WEB_APP_URL, ...). Those are
# read by two different layers — server (last-wins, fine) and the browser bundle
# (NEXT_PUBLIC_* inlined at build time) — so a live original can leave the browser
# pointed at the REMOTE db while the server is on local (split-brain). We comment the
# originals out with a reversible tag so the managed block is the only definition;
# setprod strips the tag and the file round-trips byte-for-byte back to prod.
OFF_TAG="#avoca-dev-off# "
_disable_dupes() { # $1=file, rest=keys to comment out
  local f="$1"; shift; [ -f "$f" ] || return 0
  local k
  for k in "$@"; do perl -i -pe "s{^(${k}=)}{${OFF_TAG}\$1}" "$f"; done
}
_enable_dupes() { # $1=file — restore every tagged original
  local f="$1"; [ -f "$f" ] || return 0
  perl -i -pe "s{^\Q${OFF_TAG}\E}{}" "$f"
}
# NEXT_PUBLIC_* are baked into .next at build time, so a stale build keeps serving the
# old db URL to the browser after a switch. Wipe it so the next `pnpm dev` rebuilds clean.
_wipe_next() { local wt="$1"; rm -rf "$wt/apps/web/.next" "$wt/apps/dashboard/.next" 2>/dev/null || true; }
# Bring the local Supabase stack up (excluding the flaky/unneeded containers), down, or cycle it.
_stack_up() {
  need supabase
  log "starting local stack${SUPABASE_EXCLUDE:+ (excluding $SUPABASE_EXCLUDE)}"
  local out rc=0
  out="$( cd "$LOCAL_DB_DIR" && supabase start ${SUPABASE_EXCLUDE:+-x "$SUPABASE_EXCLUDE"} 2>&1 )" || rc=$?
  printf '%s\n' "$out" | grep -viE '"[A-Z0-9_]+":|^\s*[{}]|Skipped|Image is already|A new version|We recommend|S3_PROTOCOL|STORAGE_S3' | tail -6 | sed 's/^/  /'
  return $rc
}
cmd_db() {
  local action="${1:?usage: avoca-dev db <up|down|cycle|setdev|setprod|status> [worktree]}"
  case "$action" in
    up)    _stack_up; return ;;
    down)  need supabase; log "stopping local stack (data kept; pass --no-backup to wipe)"; ( cd "$LOCAL_DB_DIR" && supabase stop "${@:2}" ) | tail -3 | sed 's/^/  /'; return ;;
    cycle) need supabase; log "cycling local stack"; ( cd "$LOCAL_DB_DIR" && supabase stop >/dev/null 2>&1 || true ); _stack_up; return ;;
  esac
  local wt; wt="$(resolve_worktree "${2:-}")"
  local web="$wt/apps/web/.env.local" dash="$wt/apps/dashboard/.env.local"
  local env; env="$(sb_env)"; LOCAL_API="$(sbval "$env" API_URL)"; LOCAL_API="${LOCAL_API:-http://127.0.0.1:54321}"

  if [ "$action" = status ]; then
    echo "avoca-dev db  ($(basename "$wt"))"
    for pair in "apps/web:$web" "apps/dashboard:$dash"; do
      local app="${pair%%:*}" f="${pair#*:}" url tag
      [ -f "$f" ] || { echo "  $app: (no .env.local)"; continue; }
      url="$(grep -E '^NEXT_PUBLIC_SUPABASE_URL=' "$f" | tail -1 | cut -d= -f2- | tr -d '"')"
      case "$url" in *127.0.0.1*|*localhost*) tag="LOCAL";; *) tag="prod ";; esac
      echo "  $app: $tag  (supabase=$url)"
    done; return 0
  fi

  # keys the managed block re-defines — must not stay live as originals in dev mode
  local WEB_DUP_KEYS="NEXT_PUBLIC_SUPABASE_URL NEXT_PUBLIC_SUPABASE_ANON_KEY SUPABASE_SECRET_KEY POSTGRES_HOST POSTGRES_PORT POSTGRES_DB POSTGRES_USER POSTGRES_PASSWORD POSTGRES_URL NEXT_PUBLIC_DASHBOARD_URL"
  local DASH_DUP_KEYS="NEXT_PUBLIC_SUPABASE_URL NEXT_PUBLIC_SUPABASE_ANON_KEY SUPABASE_SECRET_KEY POSTGRES_URL WEB_APP_URL NEXT_PUBLIC_WEB_APP_URL"

  if [ "$action" = setprod ] || [ "$action" = prod ]; then
    strip_block "$web"; [ -f "$dash" ] && strip_block "$dash"
    _enable_dupes "$web"; [ -f "$dash" ] && _enable_dupes "$dash"
    _wipe_next "$wt"
    log "$(basename "$wt") → PROD (restored originals; reverts to Vercel-pulled values; .next wiped)"
    echo "  restart any running dev server to apply."; return 0
  fi
  [ "$action" = setdev ] || [ "$action" = dev ] || [ "$action" = local ] || die "action must be setdev, setprod, or status"

  # Read the local keys BEFORE mutating any env file. If the stack is down, sbval returns
  # empty — fail HERE with the file untouched, rather than after strip_block/_disable_dupes
  # (which would leave the originals commented AND no managed block = zero live Supabase URL).
  local anon svc; anon="$(sbval "$env" ANON_KEY)"; svc="$(sbval "$env" SERVICE_ROLE_KEY)"
  [ -n "$anon" ] && [ -n "$svc" ] || die "couldn't read local Supabase keys — is the stack up? (run: avoca-dev db up)"

  strip_block "$web"; [ -f "$dash" ] && strip_block "$dash"
  _disable_dupes "$web" $WEB_DUP_KEYS
  { echo ""; echo "$BEGIN_MARK"
    echo "POSTGRES_HOST=127.0.0.1"; echo "POSTGRES_PORT=54322"; echo "POSTGRES_DB=postgres"
    echo "POSTGRES_USER=postgres"; echo "POSTGRES_PASSWORD=postgres"
    echo "POSTGRES_URL=$LOCAL_PG_URL"
    echo "NEXT_PUBLIC_SUPABASE_URL=$LOCAL_API"; echo "NEXT_PUBLIC_SUPABASE_ANON_KEY=$anon"
    echo "SUPABASE_SECRET_KEY=$svc"; echo "NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3002"
    echo "$END_MARK"; } >> "$web"
  if [ -f "$dash" ]; then
    _disable_dupes "$dash" $DASH_DUP_KEYS
    { echo ""; echo "$BEGIN_MARK"
      echo "NEXT_PUBLIC_SUPABASE_URL=$LOCAL_API"; echo "NEXT_PUBLIC_SUPABASE_ANON_KEY=$anon"
      echo "SUPABASE_SECRET_KEY=$svc"; echo "POSTGRES_URL=$LOCAL_PG_URL"
      echo "WEB_APP_URL=http://localhost:3000"; echo "NEXT_PUBLIC_WEB_APP_URL=http://localhost:3000"
      echo "$END_MARK"; } >> "$dash"
  fi
  _wipe_next "$wt"
  log "$(basename "$wt") → DEV/local  (web:3000 dashboard:3002 → $LOCAL_API / pg 54322; .next wiped)"
  echo "  restart any running dev server to apply (or use 'avoca-dev up')."
}

# ── up: seamless local dev in one shot ────────────────────────────────────
cmd_up() {
  local wt; wt="$(resolve_worktree "${1:-}")"
  # Bring the local DB stack up (idempotent — no-op if already running). This is
  # the ONLY process `up` starts: the database. It does NOT run the app dev
  # server — you start `pnpm dev` / `pnpm start` yourself.
  local running; running="$(docker ps --format '{{.Names}}' 2>/dev/null | grep -c "supabase_.*$(basename "$LOCAL_DB_DIR")" || true)"
  [ "${running:-0}" -gt 0 ] || _stack_up
  cmd_db setdev "$wt" >/dev/null
  local app nx
  for app in web dashboard; do
    nx="$wt/apps/$app/.next"
    if [ -d "$nx" ] && grep -rqlF "$PROD_PROJECT_REF" "$nx/static" 2>/dev/null; then
      log "dropping stale $app/.next (prod URL was baked into the bundle)"; rm -rf "$nx"
    fi
  done
  log "$(basename "$wt") → LOCAL db up + env pointed local + stale bundle dropped."
  echo "  now start the app yourself:  cd $wt/apps/web && pnpm dev"
}

# ── oauth: wire Google sign-in on the local stack ─────────────────────────
cmd_oauth() {
  local cid="${1:?usage: avoca-dev oauth <google-client-id> <google-secret>}"; local secret="${2:?need the client secret}"
  local cfg="$LOCAL_DB_DIR/supabase/config.toml"
  [ -f "$cfg" ] || die "no config.toml at $cfg (run 'avoca-dev setup' first)"
  if grep -q "^\[auth.external.google\]" "$cfg"; then
    log "google stanza already present in config.toml — leaving it, updating env"
  else
    log "add [auth.external.google] to config.toml"
    { echo ""; echo "[auth.external.google]"; echo "enabled = true"
      echo 'client_id = "env(SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID)"'
      echo 'secret = "env(SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET)"'; } >> "$cfg"
  fi
  # supabase reads these from the LOCAL_DB_DIR/.env at start
  local envf="$LOCAL_DB_DIR/.env"; touch "$envf"
  grep -q '^SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=' "$envf" || echo "SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=$cid" >> "$envf"
  grep -q '^SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET='    "$envf" || echo "SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=$secret" >> "$envf"
  log "restart the stack to apply (preserves data): (cd $LOCAL_DB_DIR && supabase stop && supabase start)"
  echo "  In Google Cloud Console, the OAuth client's Authorized redirect URI must be:"
  echo "    http://127.0.0.1:54321/auth/v1/callback"
  echo "  Then browse the app at http://127.0.0.1:3000 (matches site_url; cookies need one host)."
}

# ── trim: cut the Supabase stack to the services we actually use ──────────
cmd_trim() {
  local cfg="$LOCAL_DB_DIR/supabase/config.toml"
  [ -f "$cfg" ] || die "no config.toml at $cfg"
  log "disabling unused services (analytics, storage, realtime, edge_runtime) in config.toml"
  # Set enabled=false under each service stanza. Conservative: keep studio + inbucket.
  for svc in analytics storage realtime edge_runtime; do
    if grep -q "^\[$svc\]" "$cfg"; then
      awk -v s="$svc" '
        $0=="["s"]"{inb=1; print; next}
        inb && /^\[/{inb=0}
        inb && /^enabled *=/{print "enabled = false"; done=1; next}
        {print}
      ' "$cfg" > "$cfg.tmp" && mv "$cfg.tmp" "$cfg"
    fi
  done
  log "restart to apply (preserves data): (cd $LOCAL_DB_DIR && supabase stop && supabase start)"
}

# ── twilio: provision / deprovision / audit test subaccounts ─────────────
# Real actions on Avoca's ISV Twilio master account, but SAFE: every subaccount
# we create is tagged FN_PREFIX in its FriendlyName, and deprovision refuses to
# touch any subaccount whose FriendlyName lacks that marker — so automated
# teardown can never close a real customer's subaccount.
FN_PREFIX="avoca-dev-local"
_twilio_creds() {
  need python3
  local f="$PROD_ENV_FILE"
  ISV_SID="$(grep -E '^TWILIO_ISV_ACCOUNT_SID=' "$f" 2>/dev/null | tail -1 | cut -d= -f2- | tr -d '"')"
  ISV_TOK="$(grep -E '^TWILIO_ISV_AUTH_TOKEN=' "$f" 2>/dev/null | tail -1 | cut -d= -f2- | tr -d '"')"
  [ -n "$ISV_SID" ] && [ -n "$ISV_TOK" ] || die "no TWILIO_ISV_ACCOUNT_SID/AUTH_TOKEN in $f (run 'vercel env pull' there)"
}
# Non-fatal creds load (returns 1 instead of dying) — used by seed's best-effort provisioning.
_twilio_creds_soft() {
  ISV_SID="$(grep -E '^TWILIO_ISV_ACCOUNT_SID=' "$PROD_ENV_FILE" 2>/dev/null | tail -1 | cut -d= -f2- | tr -d '"')"
  ISV_TOK="$(grep -E '^TWILIO_ISV_AUTH_TOKEN=' "$PROD_ENV_FILE" 2>/dev/null | tail -1 | cut -d= -f2- | tr -d '"')"
  [ -n "$ISV_SID" ] && [ -n "$ISV_TOK" ]
}
_tw() { curl -s -u "$ISV_SID:$ISV_TOK" "$@"; }               # authed as ISV master
_json() { python3 -c "import sys,json; d=json.load(sys.stdin); print($1)" 2>/dev/null; }

cmd_twilio() {
  local action="${1:?usage: avoca-dev twilio <provision|deprovision|status> [team]}"; shift || true
  _twilio_creds
  case "$action" in
    provision)   _tw_provision "$@";;
    deprovision) _tw_deprovision "$@";;
    status)      _tw_status "$@";;
    *) die "twilio action must be provision, deprovision, or status";;
  esac
}

# provision: no arg = every local team lacking a subaccount (the seed); or one team.
_tw_provision() {
  if [ -n "${1:-}" ]; then _tw_provision_one "$1"; return; fi
  local ids; ids="$(lsql -tAc "select t.id from teams t where not exists (select 1 from team_twilio_configs c where c.team_id=t.id) order by t.id" 2>/dev/null)"
  [ -n "$ids" ] || { echo "every local team already has a subaccount — nothing to provision"; return 0; }
  echo "provisioning subaccounts for local teams without one…"
  while read -r id; do [ -n "$id" ] && _tw_provision_one "$id"; done <<< "$ids"
}
_tw_provision_one() {
  local team="$1"
  local have; have="$(lsql -tAc "select subaccount_sid from team_twilio_configs where team_id=$team limit 1" 2>/dev/null)"
  [ -z "$have" ] || { echo "  team $team already has $have — skip"; return 0; }
  local fn="$FN_PREFIX team $team"
  local resp; resp="$(_tw -X POST "https://api.twilio.com/2010-04-01/Accounts.json" --data-urlencode "FriendlyName=$fn")"
  local sid tok; sid="$(printf '%s' "$resp" | _json "d.get('sid','')")"; tok="$(printf '%s' "$resp" | _json "d.get('auth_token','')")"
  [ -n "$sid" ] || die "subaccount create failed for team $team: $(printf '%s' "$resp" | head -c 200)"
  lsql -q -c "insert into team_twilio_configs (team_id, subaccount_sid, subaccount_auth_token) values ($team, '$sid', '$tok');" \
    || die "subaccount $sid created but DB insert failed — close $sid manually"
  log "team $team → $sid  ('$fn')"
}

# deprovision: no arg = reclaim EVERY local subaccount (walk-away teardown); or one.
# Tag-gated: only ever closes subaccounts whose FriendlyName carries FN_PREFIX,
# so it can never close a real customer's — untagged rows are skipped + flagged.
_tw_deprovision() {
  if [ -n "${1:-}" ]; then _tw_deprovision_one "$1"; return; fi
  local ids; ids="$(lsql -tAc "select team_id from team_twilio_configs order by team_id" 2>/dev/null)"
  [ -n "$ids" ] || { echo "no subaccounts recorded — nothing to deprovision"; return 0; }
  echo "reclaiming all local subaccounts (tag-gated on '$FN_PREFIX')…"
  while read -r id; do [ -n "$id" ] && _tw_deprovision_one "$id"; done <<< "$ids"
}
_tw_deprovision_one() {
  local team="$1"
  local sid; sid="$(lsql -tAc "select subaccount_sid from team_twilio_configs where team_id=$team limit 1" 2>/dev/null)"
  [ -n "$sid" ] || { echo "  team $team: no subaccount config — skip"; return 0; }
  local fn; fn="$(_tw "https://api.twilio.com/2010-04-01/Accounts/$sid.json" | _json "d.get('friendly_name','')")"
  case "$fn" in
    "$FN_PREFIX"*) : ;;
    *) echo "  team $team: SKIP $sid — FriendlyName '$fn' lacks the '$FN_PREFIX' tag (not closing; rename the team with the tag if it IS a local test one)"; return 0;;
  esac
  # Closing a subaccount releases its numbers automatically — no separate release
  # call needed (and that call was the fragile step that aborted under set -e).
  local st; st="$(_tw -X POST "https://api.twilio.com/2010-04-01/Accounts/$sid.json" --data-urlencode "Status=closed" | _json "d.get('status','?')" || true)"
  log "team $team → subaccount $sid closed (status=${st:-?}); numbers released"
  lsql -q -c "delete from team_twilio_configs where team_id=$team; delete from phone_numbers where team_id=$team and phone_number not like '+1999555%';" || true
}

_tw_status() {
  echo "avoca-dev twilio — subaccounts we provisioned (from team_twilio_configs):"
  local any=0 team sid
  while IFS='|' read -r team sid; do
    [ -n "$sid" ] || continue; any=1
    printf '    team %-8s %s  %s\n' "$team" "$sid" \
      "$(_tw "https://api.twilio.com/2010-04-01/Accounts/$sid.json" | _json "d.get('friendly_name','?')+' ['+d.get('status','?')+']'")"
  done < <(lsql -tAc "select team_id||'|'||subaccount_sid from team_twilio_configs order by team_id" 2>/dev/null)
  [ "$any" = 1 ] || echo "    (none)"
}

# ── status: the whole picture ─────────────────────────────────────────────
cmd_status() {
  echo "avoca-dev status"
  echo "  local db dir: $LOCAL_DB_DIR"
  local n; n="$(docker ps --format '{{.Names}}' 2>/dev/null | grep -c "supabase_.*$(basename "$LOCAL_DB_DIR")" || true)"
  echo "  supabase containers: ${n:-0}"
  local t; t="$(lsql -tAc "select count(*) from teams" 2>/dev/null || echo '?')"
  echo "  local db teams: $t   (schema-only mirror + your seed)"
  echo "  worktree pointers ($WORKTREES_DIR):"
  [ -d "$WORKTREES_DIR" ] || { echo "    (none)"; return 0; }
  local d found=0
  for d in "$WORKTREES_DIR"/*/; do
    [ -d "$d/apps/web" ] || continue
    found=1
    printf '    %-30s web=%-5s dash=%s\n' "$(basename "$d")" \
      "$(ptr_tag "$d/apps/web/.env.local")" "$(ptr_tag "$d/apps/dashboard/.env.local")"
  done
  [ "$found" = 1 ] || echo "    (no avoca-next worktrees found)"
}

# ── clear: tear the whole local-dev setup back down ───────────────────────
# The inverse of standing it up. For every worktree currently pointed at the
# LOCAL db (the main clone + each worktree), run `db setprod` so its env round-
# trips back to the Vercel-pulled prod values. Then wipe the local db and stop
# the Supabase stack, so the next `db up` (or `setup`) starts from clean.
#   avoca-dev clear             # setprod every LOCAL worktree, then wipe + stop the stack
#   avoca-dev clear --keep-db   # same, but keep the stack's data (just stop it)
cmd_clear() {
  local keepdb=0
  case "${1:-}" in --keep-db|--keep) keepdb=1 ;; "" ) : ;; *) die "usage: avoca-dev clear [--keep-db]" ;; esac

  # 1. Revert every worktree that's on LOCAL back to PROD (env round-trips).
  local reverted=0 d
  for d in "$AVOCA_NEXT_DIR" "$WORKTREES_DIR"/*/; do
    [ -d "$d/apps/web" ] || continue
    if [ "$(ptr_tag "$d/apps/web/.env.local")" = LOCAL ] \
       || [ "$(ptr_tag "$d/apps/dashboard/.env.local")" = LOCAL ]; then
      log "setprod $(basename "$d")"
      cmd_db setprod "$d" >/dev/null
      reverted=$((reverted + 1))
    fi
  done
  if [ "$reverted" = 0 ]; then log "no worktrees were on LOCAL — nothing to revert"; else log "reverted $reverted worktree(s) → PROD"; fi

  # 2. Stop the stack — wiping its data unless --keep-db.
  need supabase
  if [ "$keepdb" = 1 ]; then
    log "stopping local stack (data kept)"
    ( cd "$LOCAL_DB_DIR" && supabase stop ) | tail -3 | sed 's/^/  /'
  else
    log "wiping + stopping local stack (--no-backup)"
    ( cd "$LOCAL_DB_DIR" && supabase stop --no-backup ) | tail -3 | sed 's/^/  /'
  fi
  log "cleared. to rebuild:  avoca-dev db up   (data kept)   ·   avoca-dev setup   (fresh snapshot)"
}

# ── dispatch ──────────────────────────────────────────────────────────────
case "${1:-}" in
  setup)   shift; cmd_setup "$@";;
  reference) shift; cmd_reference "$@";;
  duplicate-bp)   shift; cmd_duplicate_bp "$@";;
  duplicate-team) shift; cmd_duplicate_team "$@";;
  dup-calls)      shift; cmd_dup_calls "$@";;
  delete-team)    shift; cmd_delete_team "$@";;
  reset)   shift; cmd_reset "$@";;
  grants)  shift; cmd_grants "$@";;
  ledger)  shift; cmd_ledger "$@";;
  seed)    shift; cmd_seed "$@";;
  migrate) shift; cmd_migrate "$@";;
  types)   shift; cmd_types "$@";;
  db)      shift; cmd_db "$@";;
  up)      shift; cmd_up "$@";;
  oauth)   shift; cmd_oauth "$@";;
  trim)    shift; cmd_trim "$@";;
  twilio)  shift; cmd_twilio "$@";;
  status)  shift; cmd_status "$@";;
  clear)   shift; cmd_clear "$@";;
  ""|-h|--help|help) sed -n '2,30p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//';;
  *) die "unknown command '$1' (try: avoca-dev help)";;
esac
