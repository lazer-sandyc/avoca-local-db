 /**
- * Wrap Inngest handlers passed to `serve({ functions: [...] })` when they should register only on prod.
- * When not prod, we still reference `fn` so bindings passed from imports stay “used” for TS/ESLint and editor import cleanup.
+ * True when a job's id is in `INNGEST_LOCAL_ENABLED_CRONS` (a comma-separated
+ * list). This is how a developer opts a specific prod-only job into running on
+ * their machine — set by tooling (`avoca-dev cron enable <id>`) in `.env.local`,
+ * never in code. Empty/unset list matches nothing, so the default is unchanged.
+ */
+export const isCronLocallyEnabled = (fn: unknown): boolean => {
+  const enabled = (process.env.INNGEST_LOCAL_ENABLED_CRONS ?? '')
+    .split(',')
+    .map((id) => id.trim())
+    .filter(Boolean);
+  if (enabled.length === 0) {
+    return false;
+  }
+  // Inngest functions expose `.id()`; anything without it can't be allowlisted.
+  const id =
+    typeof (fn as { id?: () => string })?.id === 'function'
+      ? (fn as { id: () => string }).id()
+      : undefined;
+  return id !== undefined && enabled.includes(id);
+};
+
+/**
+ * Wrap Inngest handlers passed to `serve({ functions: [...] })` when they should
+ * register only on prod.
+ *
+ * Off prod, a job stays unregistered — EXCEPT when the developer has explicitly
+ * opted it in for local execution AND the process is pointed at a local
+ * database. That second path is what lets someone run a specific production cron
+ * on their machine without touching code: `avoca-dev cron enable <id>` adds the
+ * id to `INNGEST_LOCAL_ENABLED_CRONS` in `.env.local`, and it registers here.
+ * Gated on {@link checkIfLocalDatabase} so an opted-in job can only ever run
+ * against a local database — never double-fire against prod's own cron, never
+ * write prod. Default behaviour (no opt-in) is exactly as before.
+ *
+ * When not registering, we still reference `fn` so imported bindings stay
+ * "used" for TS/ESLint and editor import cleanup.
  */
 export const enableOnlyOnProd = <T>(fn: T): T[] => {
   if (checkIfProductionEnvironment()) {
     return [fn];
   }
+  if (checkIfLocalDatabase() && isCronLocallyEnabled(fn)) {
+    return [fn];
+  }
   void fn;
   return [];
 };
@@ -28,3 +65,20 @@ export const enableOnProdOrInngestDev = <T>(fn: T): T[] => {
   void fn;
   return [];
 };
+
+/**
+ * True when the process is pointed at a local database.
+ *
+ * Reads the exact var the write client connects with
+ * (`NEXT_PUBLIC_SUPABASE_URL`) and nothing else. That is deliberate: keying on
+ * the same value the writes use makes "registers locally" and "writes locally"
+ * read from one source, so they can never disagree. A separate marker that
+ * claimed local while the URL still resolved to prod would reopen the exact
+ * mistake this prevents — a job that registers thinking it's local but writes
+ * prod. The URL is the source of truth for where writes land, so it is the only
+ * safe thing to gate on.
+ */
+export const checkIfLocalDatabase = () => {
+  const url = process.env.NEXT_PUBLIC_SUPABASE_URL ?? '';
+  return url.includes('127.0.0.1') || url.includes('localhost');
+};
